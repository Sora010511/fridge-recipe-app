# 楽天ウェブサービスのアプリID・アクセスキー（https://webservice.rakuten.co.jp/ で無料登録して取得）
# 2026年5月のAPI仕様移行後は、アプリケーションID・アクセスキーの両方が必須
RAKUTEN_APP_ID=
RAKUTEN_ACCESS_KEY=
# 楽天アプリ登録時に設定した「アプリケーションURL」と同じ値（Originヘッダー用）
RAKUTEN_ORIGIN=

# サーバーのポート番号
PORT=3000

# レシピ検索時に問い合わせる中カテゴリの件数上限（多いほど候補が増えるがAPI呼び出しも増える）
RECIPE_CATEGORY_LIMIT=20
